      "cell_type": "code",
      "source": [
        "# Import required libraries\n",
        "from scipy import special\n",
        "import math\n",
        "import pandas as pd\n",
        "import matplotlib.pyplot as plt\n",
        "import matplotlib.ticker as ticker\n",
        "# Data from the table\n",
        "omega_L = [0.1, 0.14, 0.17, 0.20, 0.22, 0.23]\n",
        "delta_t_cs = [15, 32.01, 51.01, 65.51, 80.01, 88.01]\n",
        "delta_t_cl = [75, 92.01, 111.01, 125.51, 140.01, 148.01]\n",
        "# Create scatter plot\n",
        "plt.scatter(\n",
        "    omega_L,\n",
        "    delta_t_cs,\n",
        "    marker='s',\n",
        "    color='orange',\n",
        "    label=r'$\\Delta t_{cs}$'\n",
        ")\n",
        "plt.scatter(\n",
        "    omega_L,\n",
        "    delta_t_cl,\n",
        "    marker='o',\n",
        "    color='blue',\n",
        "    label=r'$\\Delta t_{cl}$'\n",
        ")\n",
        "# Axis labels\n",
        "xlabel_size = 16\n",
        "ylabel_size = 16\n",
        "plt.xlabel(\n",
        "    r'$\\omega_L$ (fs$^{-1}$)',\n",
        "    fontsize=xlabel_size\n",
        ")\n",
        "plt.ylabel(\n",
        "    'Time (fs)',\n",
        "    fontsize=ylabel_size\n",
        ")\n",
        "# plt.title(\n",
        "#     r'Scatter Plot of $\\Delta t_{cs}$ and $\\Delta t_{cl}$ vs $\\omega_L$'\n",
        "# )\n",
        "# Axis formatting\n",
        "ax = plt.gca()\n",
        "ax.yaxis.set_major_formatter(\n",
        "    ticker.FormatStrFormatter('%.1f')\n",
        ")\n",
        "# Place ticks inside the frame\n",
        "ax.tick_params(\n",
        "    axis='both',\n",
        "    direction='in',\n",
        "    which='both',\n",
        "    bottom=True,\n",
        "    top=True,\n",
        "    left=True,\n",
        "    right=True\n",
        ")\n",
        "# Increase tick label size\n",
        "tick_label_size = 14\n",
        "ax.tick_params(\n",
        "    axis='both',\n",
        "    labelsize=tick_label_size\n",
        ")\n",
        "# Add legend\n",
        "plt.legend()\n",
        "# Display plot\n",
        "plt.show()"
      ],
